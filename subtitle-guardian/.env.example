# Backend Environment Variables
NODE_ENV=production
PORT=3000
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# AWS Configuration
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
AWS_COMPREHEND_REGION=us-east-1
DYNAMODB_TABLE_PREFIX=subtitle-guardian-prod

# External API Keys
OPENAI_API_KEY=sk-your-openai-api-key
OPENSUBTITLES_API_KEY=your-opensubtitles-api-key
TMDB_API_KEY=your-tmdb-api-key
OMDB_API_KEY=your-omdb-api-key

# Stripe Configuration
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_live_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Frontend Configuration
API_URL=https://api.subtitleguardian.com/api
FRONTEND_URL=https://subtitleguardian.com

# Database Configuration (if using external database)
DATABASE_URL=your-database-connection-string

# Redis Configuration (if using external Redis)
REDIS_URL=redis://localhost:6379

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Monitoring and Logging
SENTRY_DSN=your-sentry-dsn
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Security
CORS_ORIGIN=https://subtitleguardian.com
BCRYPT_ROUNDS=12

# Feature Flags
ENABLE_ANALYTICS=true
ENABLE_CACHING=true
ENABLE_EMAIL_NOTIFICATIONS=true

