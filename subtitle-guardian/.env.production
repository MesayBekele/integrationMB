# Production Environment Variables
NODE_ENV=production
PORT=3000
JWT_SECRET=production-jwt-secret-change-this-to-secure-value

# AWS Configuration
AWS_ACCESS_KEY_ID=your-aws-production-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-production-secret-access-key
AWS_REGION=us-east-1
DYNAMODB_TABLE_PREFIX=subtitle-guardian-prod

# External API Keys (production keys)
OPENAI_API_KEY=sk-your-openai-production-api-key
OPENSUBTITLES_API_KEY=your-opensubtitles-production-key
TMDB_API_KEY=your-tmdb-production-key

# Stripe Configuration (live keys)
STRIPE_SECRET_KEY=sk_live_your-stripe-live-secret-key
STRIPE_PUBLISHABLE_KEY=pk_live_your-stripe-live-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-live-webhook-secret

# URLs
API_URL=https://api.subtitleguardian.com/api
FRONTEND_URL=https://subtitleguardian.com

# Database
REDIS_URL=redis://redis:6379

# Logging
LOG_LEVEL=info

