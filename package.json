{
  "name": "cypress-e2e-framework",
  "version": "1.0.0",
  "description": "Comprehensive Cypress 11 E2E testing framework with Cucumber, data-driven testing, and Mochawesome reporting",
  "main": "index.js",
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "eject": "react-scripts eject",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --coverage --watchAll=false",
    "test:debug": "node --inspect-brk node_modules/.bin/jest --runInBand",
    "test:unit": "jest --testPathPattern=__tests__/.*\\.test\\.(js|jsx)$",
    "test:integration": "jest --testPathPattern=integration.*\\.test\\.(js|jsx)$",
    "test:lazy": "jest --testNamePattern='lazy|Lazy'",
    "cypress:run": "cypress run",
    "cypress:headed": "cypress run --headed",
    "cypress:chrome": "cypress run --browser chrome",
    "cypress:firefox": "cypress run --browser firefox",
    "cypress:edge": "cypress run --browser edge",
    "cypress:smoke": "cypress run --env tags='@smoke'",
    "cypress:regression": "cypress run --env tags='@regression'",
    "cypress:critical": "cypress run --env tags='@critical'",
    "cypress:dev": "cypress run --env environment=dev",
    "cypress:staging": "cypress run --env environment=staging",
    "cypress:prod": "cypress run --env environment=prod",
    "cypress:smoke:dev": "cypress run --env tags='@smoke',environment=dev",
    "cypress:regression:staging": "cypress run --env tags='@regression',environment=staging",
    "cypress:open": "cypress open",
    "cypress:open:dev": "cypress open --env environment=dev",
    "cypress:open:staging": "cypress open --env environment=staging",
    "report:merge": "mochawesome-merge reports/temp/*.json > reports/merged-report.json",
    "report:generate": "marge reports/merged-report.json --reportDir reports --inline",
    "report:clean": "rm -rf reports/temp && mkdir -p reports/temp",
    "cypress:full": "npm run report:clean && npm run cypress:run && npm run report:merge && npm run report:generate",
    "cypress:parallel": "cypress run --record --parallel",
    "lint": "eslint src/**/*.{js,jsx} cypress/**/*.js",
    "lint:fix": "eslint src/**/*.{js,jsx} cypress/**/*.js --fix"
  },
  "keywords": [
    "cypress",
    "e2e",
    "testing",
    "cucumber",
    "bdd",
    "automation",
    "ui-testing",
    "data-driven",
    "mochawesome"
  ],
  "author": "Your Name",
  "license": "MIT",
  "devDependencies": {
    "cypress": "^11.2.0",
    "@badeball/cypress-cucumber-preprocessor": "^15.1.5",
    "@bahmutov/cypress-esbuild-preprocessor": "^2.2.0",
    "cypress-mochawesome-reporter": "^3.4.0",
    "mochawesome": "^7.1.3",
    "mochawesome-merge": "^4.3.0",
    "mochawesome-report-generator": "^6.2.0",
    "eslint": "^8.57.0",
    "eslint-plugin-cypress": "^2.15.1",
    "prettier": "^2.8.8",
    "@testing-library/react": "^13.4.0",
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/user-event": "^14.4.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@babel/preset-react": "^7.22.0",
    "babel-jest": "^29.7.0",
    "identity-obj-proxy": "^3.0.0",
    "react-scripts": "5.0.1"
  },
  "dependencies": {
    "csv-parser": "^3.0.0",
    "moment": "^2.29.4",
    "lodash": "^4.17.21",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.8.0"
  },
  "cypress-cucumber-preprocessor": {
    "stepDefinitions": [
      "cypress/support/step_definitions/**/*.js"
    ],
    "html": {
      "enabled": true,
      "output": "reports/cucumber-html-report.html"
    },
    "json": {
      "enabled": true,
      "output": "reports/cucumber-report.json"
    },
    "messages": {
      "enabled": true,
      "output": "reports/cucumber-messages.ndjson"
    }
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}
