# Environment Configuration
CYPRESS_ENV=dev
CYPRESS_BASE_URL=https://dev.example.com
CYPRESS_API_URL=https://api-dev.example.com

# Credentials (use environment-specific values)
CYPRESS_ADMIN_USERNAME=admin@dev.com
CYPRESS_ADMIN_PASSWORD=dev_admin_pass
CYPRESS_USER_USERNAME=user@dev.com
CYPRESS_USER_PASSWORD=dev_user_pass

# Database Configuration
DB_HOST=dev-db.example.com
DB_PORT=5432
DB_NAME=app_dev
DB_SSL=false

# Feature Flags
ENABLE_DEBUG_MODE=true
ENABLE_MOCK_DATA=true
ENABLE_DETAILED_LOGGING=true

# CI/CD Configuration
CYPRESS_RECORD_KEY=your_cypress_record_key_here
GITHUB_TOKEN=your_github_token_here

# Reporting
REPORT_OUTPUT_DIR=reports
MERGE_REPORTS=true

