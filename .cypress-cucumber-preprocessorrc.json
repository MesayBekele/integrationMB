{
  "stepDefinitions": [
    "cypress/support/step_definitions/**/*.js"
  ],
  "html": {
    "enabled": true,
    "output": "reports/cucumber-html-report.html"
  },
  "json": {
    "enabled": true,
    "output": "reports/cucumber-report.json"
  },
  "messages": {
    "enabled": true,
    "output": "reports/cucumber-messages.ndjson"
  },
  "filterSpecs": true,
  "omitFiltered": true
}

